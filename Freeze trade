local dotStates = {"●  ○  ○", "●  ●  ○", "●  ●  ●", "○  ●  ●", "○  ○  ●", "○  ○  ○"}
local dotIndex = 1
local dotsRunning = true

coroutine.wrap(function()
    while dotsRunning do
        DotsLabel.Text = dotStates[dotIndex]
        dotIndex = (dotIndex % #dotStates) + 1
        wait(0.3)
    end
end)()

-- Progress bar animation over 60 seconds
coroutine.wrap(function()
    local duration = 60
    local steps = 120
    local stepTime = duration / steps
    for i = 1, steps do
        local progress = i / steps
        TweenService:Create(ProgressFill, TweenInfo.new(stepTime, Enum.EasingStyle.Linear), {
            Size = UDim2.new(progress, 0, 1, 0)
        }):Play()
        wait(stepTime)
    end
end)()

